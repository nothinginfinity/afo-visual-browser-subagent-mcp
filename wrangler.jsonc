{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "afo-visual-browser-subagent-mcp",
  "main": "src/worker.js",
  "compatibility_date": "2026-07-18",
  "compatibility_flags": ["nodejs_compat"],
  // Required secret, configured with `wrangler secret put ARTIFACT_SIGNING_SECRET`; never store its value here.
  "browser": { "binding": "BROWSER" },
  "ai": { "binding": "AI" },
  "d1_databases": [{ "binding": "DB", "database_name": "afo-visual-browser-subagent", "database_id": "a963c0b4-4e2f-4bf3-ac54-cd5fb192e928", "migrations_dir": "migrations" }],
  "r2_buckets": [{ "binding": "RECEIPTS", "bucket_name": "afo-visual-browser-receipts" }],
  "vectorize": [{ "binding": "VECTORIZE", "index_name": "afo-visual-browser-evidence" }],
  "queues": {
    "producers": [{ "binding": "AUDIT_QUEUE", "queue": "afo-visual-browser-audits" }],
    "consumers": [{ "queue": "afo-visual-browser-audits", "max_batch_size": 5, "max_batch_timeout": 10, "max_retries": 3, "dead_letter_queue": "afo-visual-browser-audits-dlq" }]
  },
  "analytics_engine_datasets": [{ "binding": "ANALYTICS", "dataset": "afo_visual_browser_events" }],
  "vars": { "WORKER_NAME": "afo-visual-browser-subagent-mcp", "OPERATING_MODE": "public_readonly" }
}
